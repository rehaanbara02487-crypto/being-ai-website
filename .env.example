# BeingAI Configuration

# Workspace root for generated projects
BEINGAI_WORKSPACE_ROOT=./data/workspaces

# SQLite database path
BEINGAI_DB_PATH=./data/beingai.db
SQLALCHEMY_ECHO=false

# LLM provider (openai | anthropic)
BEINGAI_LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BEINGAI_LLM_MODEL=gpt-4o

# GitHub (optional — for GitHub Agent)
GITHUB_TOKEN=
BEINGAI_AUTO_PUSH=false

# Safety
BEINGAI_MAX_DEBUG_RETRIES=5
BEINGAI_COMMAND_ALLOWLIST_ENABLED=false
# BEINGAI_COMMAND_ALLOWLIST=flutter,npm,pip,git,python,node

# Server
BEINGAI_HOST=127.0.0.1
BEINGAI_PORT=8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
